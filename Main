# ── B1: Correlation Matrix ───────────────────────────────────────────────────
subsection("B1: Correlation Matrix — KPIs vs DL Throughput")

corr_cols    = [EDA_TARGET] + KPI_COLS
corr_df      = df[corr_cols].dropna()
pearson_mat  = corr_df.corr(method='pearson')
spearman_mat = corr_df.corr(method='spearman')

fig, axes = plt.subplots(1, 2, figsize=(18, 8))
fig.suptitle('B1 — Correlation Matrix: KPIs vs DL Throughput\n'
             'Pearson r = linear  |  Spearman rho = monotonic / non-linear',
             fontsize=14, fontweight='bold')
cmap_div = sns.diverging_palette(220, 20, as_cmap=True)
for ax, mat, title in zip(axes,
                           [pearson_mat, spearman_mat],
                           ['Pearson r  (linear)', 'Spearman rho  (rank)']):
    mask = np.zeros_like(mat, dtype=bool)
    np.fill_diagonal(mask, True)
    sns.heatmap(mat, ax=ax, mask=mask, cmap=cmap_div, center=0,
                vmin=-1, vmax=1, annot=True, fmt='.2f',
                annot_kws={'size': 10}, linewidths=0.4, linecolor='white',
                cbar_kws={'shrink': 0.75, 'label': title})
    ax.set_title(title, fontsize=12, fontweight='bold')
    ax.tick_params(axis='x', rotation=45, labelsize=10)
    ax.tick_params(axis='y', rotation=0,  labelsize=10)
plt.tight_layout()
save_eda('b1_correlation_matrix')

target_pearson  = pearson_mat[EDA_TARGET].drop(EDA_TARGET).sort_values(ascending=False)
target_spearman = spearman_mat[EDA_TARGET].drop(EDA_TARGET).sort_values(ascending=False)

print(f"\n  Pearson r with {EDA_TARGET} (ranked):")
for feat in target_pearson.index:
    pr = target_pearson[feat]; sr = target_spearman[feat]
    strength  = 'STRONG' if abs(pr)>0.5 else 'MODERATE' if abs(pr)>0.3 else 'WEAK'
    direction = 'positive' if pr > 0 else 'negative'
    print(f"    {feat:<25}  r={pr:+.3f}  rho={sr:+.3f}  [{strength}, {direction}]")

fig, ax = plt.subplots(figsize=(SLIDE_W, SLIDE_H))
fig.suptitle('B1 — KPI Pearson Correlation with DL Throughput (ranked)',
             fontsize=14, fontweight='bold')
colors = ['#27ae60' if v > 0 else '#e74c3c' for v in target_pearson.values]
bars   = ax.barh(target_pearson.index, target_pearson.values,
                 color=colors, edgecolor='white', height=0.6)
for bar, val in zip(bars, target_pearson.values):
    xpos = val + 0.005 if val >= 0 else val - 0.005
    ha   = 'left'      if val >= 0 else 'right'
    ax.text(xpos, bar.get_y() + bar.get_height()/2,
            f'{val:+.3f}', va='center', ha=ha, fontsize=10)
ax.axvline(0,    color='black',   lw=1,   alpha=0.5)
ax.axvline( 0.3, color='#27ae60', lw=1.2, ls='--', alpha=0.6, label='|r|=0.3 moderate')
ax.axvline(-0.3, color='#27ae60', lw=1.2, ls='--', alpha=0.6)
ax.axvline( 0.5, color='#2980b9', lw=1.2, ls=':',  alpha=0.6, label='|r|=0.5 strong')
ax.axvline(-0.5, color='#2980b9', lw=1.2, ls=':',  alpha=0.6)
ax.set_xlabel('Pearson r  with  DL Throughput')
ax.set_title('Green = positive predictor  |  Red = negative predictor')
ax.legend(fontsize=10); ax.grid(axis='x', alpha=0.3)
plt.tight_layout()
save_eda('b1_correlation_ranked_bar')


# ── B4: Domain Hypothesis Testing ────────────────────────────────────────────
subsection("B4: Domain Hypothesis Testing")


def hypothesis_scatter(ax, x_col, y_col, title, xlabel,
                       expected_direction, n_bins=20, color='steelblue'):
    valid  = df[[x_col, y_col]].dropna()
    x_vals = valid[x_col]; y_vals = valid[y_col]
    idx    = valid.sample(min(5000, len(valid)), random_state=42).index
    ax.scatter(valid.loc[idx, x_col], valid.loc[idx, y_col],
               alpha=0.08, s=5, color=color)
    bins  = pd.cut(x_vals, bins=n_bins)
    means = y_vals.groupby(bins, observed=True).mean()
    mids  = [(b.left+b.right)/2 for b in means.index]
    ax.plot(mids, means.values, color='tomato', lw=2.5, label='Bin-mean trend')
    r, p  = pearsonr(x_vals, y_vals)
    p_str = 'p < 0.001' if p < 0.001 else f'p = {p:.4f}'
    confirmed = (r>0.10 and p<0.05) if expected_direction=='positive' \
                else (r<-0.05 and p<0.05)
    verdict  = 'CONFIRMED' if confirmed else 'REJECTED'
    clr_edge = '#27ae60'   if confirmed else '#e74c3c'
    ax.text(0.04, 0.96, f'Pearson r = {r:+.3f}\n{p_str}\n{verdict}',
            transform=ax.transAxes, fontsize=9, va='top',
            bbox=dict(boxstyle='round,pad=0.35', facecolor='white',
                      edgecolor=clr_edge, alpha=0.92),
            color=clr_edge, fontweight='bold')
    ax.set_xlabel(xlabel, fontsize=10)
    ax.set_ylabel('DL Throughput (Mbps)', fontsize=10)
    ax.set_title(title, fontsize=11, fontweight='bold')
    ax.legend(fontsize=9); ax.grid(alpha=0.3)
    return r, p, verdict


fig = plt.figure(figsize=(22, 30))
fig.suptitle('B4 — KPI vs DL Throughput: Hypothesis Testing\n'
             '5G Simulation Dataset — Telecom-validated relationships',
             fontsize=15, fontweight='bold', y=1.002)

n_hyp_rows = 4
gs  = gridspec.GridSpec(n_hyp_rows + 1, 3, figure=fig,
                        hspace=0.70, wspace=0.38, top=0.97, bottom=0.03)
pal = ['#3498db','#e74c3c','#9b59b6','#1abc9c','#f39c12','#e67e22','#2ecc71',
       '#e91e63','#00bcd4']

ax = fig.add_subplot(gs[0, 0])
if 'SINR' in df.columns:
    r, p, v = hypothesis_scatter(
        ax, 'SINR', EDA_TARGET,
        'H1: SINR up -> Throughput up\nShannon: C = B*log2(1+SINR)',
        'SINR (dB)', 'positive', color=pal[0])
    hyp_results.append(('H1: SINR up -> Throughput up', r, p, v,
                         'Shannon capacity: C=B*log2(1+SINR); SINR drives MCS selection'))
else:
    ax.text(0.5, 0.5, 'SINR not yet available\nAdd SINRDL_UE_Id_0_499.csv',
            transform=ax.transAxes, ha='center', va='center',
            fontsize=10, color='grey',
            bbox=dict(boxstyle='round', facecolor='#f8f9fa', edgecolor='grey'))
    ax.set_title('H1: SINR up -> Throughput up\n(file not yet loaded)',
                 fontsize=11, fontweight='bold')
    ax.axis('off')

ax = fig.add_subplot(gs[0, 1])
r, p, v = hypothesis_scatter(
    ax, 'PRBS', EDA_TARGET,
    'H2: PRBs up -> Throughput up\nMore PRBs = more bandwidth',
    'PRBs Allocated', 'positive', color=pal[1])
hyp_results.append(('H2: PRBs up -> Throughput up', r, p, v,
                     'Each PRB = 12 subcarriers; more PRBs -> wider effective bandwidth'))

ax = fig.add_subplot(gs[0, 2])
r, p, v = hypothesis_scatter(
    ax, 'BLER', EDA_TARGET,
    'H3: BLER up -> Throughput down\nHigh BLER -> HARQ retx + lower MCS',
    'Block Error Rate (BLER)', 'negative', color=pal[2])
hyp_results.append(('H3: BLER up -> Throughput down', r, p, v,
                     'BLER > 10% triggers MCS fallback and HARQ retransmissions'))

ax = fig.add_subplot(gs[1, 0])
r, p, v = hypothesis_scatter(
    ax, 'RU', EDA_TARGET,
    'H4: RU up -> Per-UE Throughput down\nHigh cell load -> fewer PRBs per UE',
    'Resource Utilisation (RU)', 'negative', color=pal[3])
hyp_results.append(('H4: RU up -> Per-UE Throughput down', r, p, v,
                     'High RU = congested cell; scheduler allocates fewer PRBs per UE'))

ax = fig.add_subplot(gs[1, 1])
r, p, v = hypothesis_scatter(
    ax, 'Effective_Resource', EDA_TARGET,
    'H5: Effective Resource up -> Throughput up\nPRBs*(1-BLER)',
    'Effective Resource  PRBs * (1-BLER)', 'positive', color=pal[4])
hyp_results.append(('H5: Effective Resource up -> Throughput up', r, p, v,
                     'PRBs*(1-BLER) combines resource quantity and channel quality'))

ax = fig.add_subplot(gs[1, 2])
active_grp = df[df['PRBS_Active']==1][EDA_TARGET].dropna()
idle_grp   = df[df['PRBS_Active']==0][EDA_TARGET].dropna()
bp = ax.boxplot([idle_grp.values, active_grp.values], patch_artist=True,
                labels=['Unscheduled\n(PRBs = 0)', 'Scheduled\n(PRBs > 0)'],
                medianprops={'color':'black','lw':2},
                whiskerprops={'color':'grey'}, capprops={'color':'grey'},
                flierprops={'marker':'o','ms':2,'alpha':0.15,'color':'grey'})
bp['boxes'][0].set(facecolor='#e74c3c', alpha=0.7)
bp['boxes'][1].set(facecolor='#27ae60', alpha=0.7)
stat, p_val = mannwhitneyu(idle_grp, active_grp, alternative='less')
v_str    = 'CONFIRMED' if p_val < 0.05 else 'REJECTED'
clr_edge = '#27ae60' if p_val < 0.05 else '#e74c3c'
p_str    = 'p < 0.001' if p_val < 0.001 else f'p = {p_val:.4f}'
ax.text(0.04, 0.96, f'Mann-Whitney\n{p_str}\n{v_str}',
        transform=ax.transAxes, fontsize=9, va='top',
        bbox=dict(boxstyle='round,pad=0.35', facecolor='white',
                  edgecolor=clr_edge, alpha=0.92),
        color=clr_edge, fontweight='bold')
ax.set_ylabel('DL Throughput (Mbps)')
ax.set_title('H6: Scheduled vs Unscheduled UEs\nPRBs=0 -> zero throughput (DTX)',
             fontsize=11, fontweight='bold')
ax.grid(axis='y', alpha=0.3)
hyp_results.append(('H6: Scheduled UEs have higher throughput', np.nan, p_val, v_str,
                     'PRBs=0 means no scheduling in that TTI; throughput = 0 by definition'))

ax = fig.add_subplot(gs[2, 0])
if 'Distance_m' in df.columns:
    r, p, v = hypothesis_scatter(
        ax, 'Distance_m', EDA_TARGET,
        'H7: Distance up -> Throughput down\nFriis path loss: P_rx proportional to 1/d^2',
        'Distance from centroid (m, 99th pctl clipped)', 'negative', color=pal[5])
    hyp_results.append(('H7: Distance up -> Throughput down', r, p, v,
                         'Path loss: P_rx proportional to 1/d^2; farther UEs have lower SINR and MCS'))
else:
    ax.text(0.5, 0.5, 'Positions not yet available\nAdd Positions file',
            transform=ax.transAxes, ha='center', va='center',
            fontsize=10, color='grey',
            bbox=dict(boxstyle='round', facecolor='#f8f9fa', edgecolor='grey'))
    ax.set_title('H7: Distance up -> Throughput down\n(Positions file not yet loaded)',
                 fontsize=11, fontweight='bold')
    ax.axis('off')

ax = fig.add_subplot(gs[2, 1])
if 'MobileState_Enc' in df.columns and 'MobileState' in df.columns:
    state_order  = ['stationary', 'walking', 'driving']
    state_groups = [df[df['MobileState'].str.lower()==s][EDA_TARGET].dropna().values
                    for s in state_order
                    if s in df['MobileState'].str.lower().values]
    state_labels = [s.capitalize() for s in state_order
                    if s in df['MobileState'].str.lower().values]
    if len(state_groups) >= 2:
        vp = ax.violinplot(state_groups, positions=range(len(state_labels)),
                           showmedians=True, showextrema=True, widths=0.7)
        mob_colors = ['#27ae60','#3498db','#e74c3c']
        for i, body in enumerate(vp['bodies']):
            body.set_facecolor(mob_colors[i % len(mob_colors)]); body.set_alpha(0.65)
        vp['cmedians'].set_color('black'); vp['cmedians'].set_linewidth(2)
        ax.set_xticks(range(len(state_labels)))
        ax.set_xticklabels(state_labels)
        stat_kw, p_kw = kruskal(*state_groups)
        v8 = 'CONFIRMED' if p_kw < 0.05 else 'REJECTED'
        clr8 = '#27ae60' if 'CONFIRMED' in v8 else '#e74c3c'
        p8_str = 'p < 0.001' if p_kw < 0.001 else f'p = {p_kw:.4f}'
        ax.text(0.04, 0.96, f'Kruskal-Wallis\n{p8_str}\n{v8}',
                transform=ax.transAxes, fontsize=9, va='top',
                bbox=dict(boxstyle='round,pad=0.35', facecolor='white',
                          edgecolor=clr8, alpha=0.92),
                color=clr8, fontweight='bold')
        ax.set_ylabel('DL Throughput (Mbps)')
        ax.set_title('H8: Mobility up -> Throughput down\nDoppler effect',
                     fontsize=11, fontweight='bold')
        ax.grid(axis='y', alpha=0.3)
        hyp_results.append(('H8: Mobility up -> Throughput down', np.nan, p_kw, v8,
                             'Doppler effect: moving UEs have stale CQI; driving = worst'))
    else:
        ax.text(0.5, 0.5, 'Insufficient mobility categories', transform=ax.transAxes,
                ha='center', va='center', fontsize=10, color='grey')
        ax.axis('off')
else:
    ax.text(0.5, 0.5, 'Positions not yet available',
            transform=ax.transAxes, ha='center', va='center',
            fontsize=10, color='grey',
            bbox=dict(boxstyle='round', facecolor='#f8f9fa', edgecolor='grey'))
    ax.set_title('H8: Mobility up -> Throughput down\n(Positions file not yet loaded)',
                 fontsize=11, fontweight='bold')
    ax.axis('off')

ax = fig.add_subplot(gs[2, 2])
bler_cats  = ['Zero','Very_Low','Low','Medium','High']
bler_means = [df[df['BLER_Category']==c][EDA_TARGET].mean() for c in bler_cats
              if c in df['BLER_Category'].values]
bler_stds  = [df[df['BLER_Category']==c][EDA_TARGET].std()  for c in bler_cats
              if c in df['BLER_Category'].values]
bler_lbls  = [c.replace('_',' ') for c in bler_cats if c in df['BLER_Category'].values]
bar_cols   = ['#27ae60','#3498db','#f39c12','#e67e22','#e74c3c'][:len(bler_lbls)]
ax.bar(bler_lbls, bler_means, yerr=bler_stds, color=bar_cols,
       alpha=0.85, edgecolor='white', capsize=4,
       error_kw={'ecolor':'grey','alpha':0.5})
ax.set_xlabel('BLER Severity Category')
ax.set_ylabel('Mean DL Throughput (Mbps)  +/- 1 std')
ax.set_title('H9: BLER Severity -> Throughput down',
             fontsize=11, fontweight='bold')
ax.grid(axis='y', alpha=0.3)
r9, p9 = pearsonr(df['BLER_Cat_Enc'], df[EDA_TARGET])
v9 = 'CONFIRMED' if r9 < -0.05 and p9 < 0.05 else 'REJECTED'
clr9 = '#27ae60' if 'CONFIRMED' in v9 else '#e74c3c'
p9_str = 'p < 0.001' if p9 < 0.001 else f'p={p9:.4f}'
ax.text(0.96, 0.96, f'r={r9:+.3f}\n{p9_str}\n{v9}',
        transform=ax.transAxes, fontsize=9, va='top', ha='right',
        bbox=dict(boxstyle='round,pad=0.35', facecolor='white',
                  edgecolor=clr9, alpha=0.92),
        color=clr9, fontweight='bold')
hyp_results.append(('H9: BLER severity up -> Throughput down', r9, p9, v9,
                     'Categorical view confirms BLER-THP inverse relationship'))

ax_tbl = fig.add_subplot(gs[3, :])
ax_tbl.axis('off')
if hyp_results:
    col_labels = ['Hypothesis', 'Telecom Rationale', 'Pearson r', 'p-value', 'Verdict']
    rows = []
    for h, r, p, v, rationale in hyp_results:
        r_str = f'{r:+.3f}' if not np.isnan(r) else 'N/A'
        p_str = 'p < 0.001' if p < 0.001 else f'p = {p:.4f}'
        rows.append([h, rationale, r_str, p_str, v])
    tbl = ax_tbl.table(cellText=rows, colLabels=col_labels,
                       cellLoc='center', loc='center', bbox=[0.0, 0.0, 1.0, 1.0])
    tbl.auto_set_font_size(False); tbl.set_fontsize(9)
    tbl.auto_set_column_width([0, 1, 2, 3, 4])
    for (ri, ci), cell in tbl.get_celld().items():
        if ri == 0:
            cell.set_facecolor('#2c3e50')
            cell.set_text_props(color='white', fontweight='bold')
        else:
            txt = cell.get_text().get_text()
            cell.set_facecolor('#d5f5e3' if 'CONFIRMED' in txt else
                               '#fadbd8' if 'REJECTED' in txt else '#f8f9fa')
            cell.set_text_props(
                color='#27ae60' if 'CONFIRMED' in txt else
                      '#e74c3c' if 'REJECTED' in txt else 'black',
                fontweight='bold' if ('CONFIRMED' in txt or 'REJECTED' in txt) else 'normal')
        cell.set_edgecolor('#bdc3c7')
    ax_tbl.set_title('Hypothesis Testing Summary — KPI vs DL Throughput',
                     pad=6, fontsize=12, fontweight='bold')
plt.tight_layout()
save_eda('b4_hypothesis_testing')


# ── B5: KPI vs Throughput Scatter Panels ─────────────────────────────────────
subsection("B5: KPI vs DL Throughput Scatter Analysis")


def kpi_scatter_slide(x_col, y_col, xlabel, title, color,
                      active_only=False, filename=None):
    data = df[df[y_col] > 0] if active_only else df
    fig, ax = plt.subplots(figsize=(SLIDE_W, SLIDE_H))
    idx  = data.sample(min(5000, len(data)), random_state=42).index
    ax.scatter(data.loc[idx, x_col], data.loc[idx, y_col],
               alpha=0.18, s=10, color=color)
    bins  = pd.cut(data[x_col], bins=20)
    means = data.groupby(bins, observed=True)[y_col].mean()
    mids  = [(b.left+b.right)/2 for b in means.index]
    ax.plot(mids, means.values, color='tomato', lw=2.8, label='Bin-mean trend')
    r, p = pearsonr(data[x_col], data[y_col])
    p_str = 'p < 0.001' if p < 0.001 else f'p = {p:.4f}'
    ax.text(0.04, 0.96, f'Pearson r = {r:+.3f}\n{p_str}',
            transform=ax.transAxes, fontsize=11, va='top',
            bbox=dict(boxstyle='round,pad=0.4', facecolor='white',
                      edgecolor='grey', alpha=0.88))
    ax.set_xlabel(xlabel)
    ax.set_ylabel('DL Throughput (Mbps)')
    ax.set_title(title, fontweight='bold', pad=12)
    ax.legend(fontsize=10); ax.grid(alpha=0.25)
    plt.tight_layout()
    fname = filename or f"b5_scatter_{x_col.lower().replace(' ','_')}"
    save_eda(fname)


def placeholder_slide(title, msg, filename):
    fig, ax = plt.subplots(figsize=(SLIDE_W, SLIDE_H))
    ax.text(0.5, 0.5, msg, transform=ax.transAxes,
            ha='center', va='center', fontsize=13, color='grey',
            bbox=dict(boxstyle='round', facecolor='#f8f9fa', edgecolor='grey'))
    ax.set_title(title, fontsize=14, fontweight='bold')
    ax.axis('off')
    plt.tight_layout()
    save_eda(filename)


