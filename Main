    best_lgbm_cls_params = lgbm_cls_random.best_params_
joblib.dump(best_lgbm_cls, f'outputs/models/stage3_{LGBM_LABEL.replace(" ","_")}_tuned.pkl')

subsection("Stage 3 — Tuned Model Evaluation")
rf_cp_tuned    = best_rf_cls.predict(X_test_reg)
_p_rf          = best_rf_cls.predict_proba(X_test_reg)
rf_cpr_tuned   = _p_rf[:,1]
rf_auc_tuned   = roc_auc_score(y_cls_test, rf_cpr_tuned)

xgb_cp_tuned   = best_xgb_cls.predict(X_test_reg)
_p_xgb         = best_xgb_cls.predict_proba(X_test_reg)
xgb_cpr_tuned  = _p_xgb[:,1]
xgb_auc_tuned  = roc_auc_score(y_cls_test, xgb_cpr_tuned)

lgbm_cp_tuned  = best_lgbm_cls.predict(X_test_reg)
_p_lgbm        = best_lgbm_cls.predict_proba(X_test_reg)
lgbm_cpr_tuned = _p_lgbm[:,1]
lgbm_auc_tuned = roc_auc_score(y_cls_test, lgbm_cpr_tuned)

rf_cp    = rf_cp_tuned;    rf_cpr   = rf_cpr_tuned;   rf_auc   = rf_auc_tuned
xgb_cp   = xgb_cp_tuned;  xgb_cpr  = xgb_cpr_tuned;  xgb_auc  = xgb_auc_tuned
lgbm_cp  = lgbm_cp_tuned; lgbm_cpr = lgbm_cpr_tuned; lgbm_auc = lgbm_auc_tuned

if   xgb_auc  >= rf_auc and xgb_auc  >= lgbm_auc:
    best_cls_name  = XGB_LABEL;       best_cls_model = best_xgb_cls
    best_cls_pred  = xgb_cp;          best_cls_proba = xgb_cpr; best_cls_auc = xgb_auc
elif lgbm_auc >= rf_auc:
    best_cls_name  = LGBM_LABEL;      best_cls_model = best_lgbm_cls
    best_cls_pred  = lgbm_cp;         best_cls_proba = lgbm_cpr; best_cls_auc = lgbm_auc
else:
    best_cls_name  = 'Random Forest'; best_cls_model = best_rf_cls
    best_cls_pred  = rf_cp;           best_cls_proba = rf_cpr; best_cls_auc = rf_auc

joblib.dump(best_cls_model,
            f"outputs/models/stage3_BEST_{best_cls_name.replace(' ','_')}_tuned.pkl")

subsection("Final Tuned Hurdle Evaluation — Full population R2")

h2_rf_tuned_pred   = np.clip(best_h2_rf.predict(X_test_reg), 0, None)
h2_xgb_tuned_pred  = np.clip(best_h2_xgb.predict(X_test_reg), 0, None)
h2_lgbm_tuned_pred = np.clip(best_h2_lgbm.predict(X_test_reg), 0, None)

h2_rf_m_tuned   = {'TestR2': r2_score(y_test_reg, h2_rf_tuned_pred),
                   'RMSE'  : np.sqrt(mean_squared_error(y_test_reg, h2_rf_tuned_pred)),
                   'MAE'   : mean_absolute_error(y_test_reg, h2_rf_tuned_pred)}
h2_xgb_m_tuned  = {'TestR2': r2_score(y_test_reg, h2_xgb_tuned_pred),
                   'RMSE'  : np.sqrt(mean_squared_error(y_test_reg, h2_xgb_tuned_pred)),
                   'MAE'   : mean_absolute_error(y_test_reg, h2_xgb_tuned_pred)}
h2_lgbm_m_tuned = {'TestR2': r2_score(y_test_reg, h2_lgbm_tuned_pred),
                   'RMSE'  : np.sqrt(mean_squared_error(y_test_reg, h2_lgbm_tuned_pred)),
                   'MAE'   : mean_absolute_error(y_test_reg, h2_lgbm_tuned_pred)}

if   h2_xgb_m_tuned['TestR2']  >= h2_rf_m_tuned['TestR2'] and \
     h2_xgb_m_tuned['TestR2']  >= h2_lgbm_m_tuned['TestR2']:
    best_h2_name  = XGB_LABEL;       best_h2_model  = best_h2_xgb
    best_h2_pred  = h2_xgb_tuned_pred; best_h2_m = h2_xgb_m_tuned
elif h2_lgbm_m_tuned['TestR2'] >= h2_rf_m_tuned['TestR2']:
    best_h2_name  = LGBM_LABEL;      best_h2_model  = best_h2_lgbm
    best_h2_pred  = h2_lgbm_tuned_pred; best_h2_m = h2_lgbm_m_tuned
else:
    best_h2_name  = 'Random Forest'; best_h2_model  = best_h2_rf
    best_h2_pred  = h2_rf_tuned_pred; best_h2_m = h2_rf_m_tuned

joblib.dump(best_h2_model,
            f"outputs/models/hurdle_stage2_BEST_{best_h2_name.replace(' ','_')}_tuned.pkl")

hurdle_tuned_results = {}
for tag, h1_m, h2_m in [
    ('Random Forest', best_h1_rf,  best_h2_rf),
    (XGB_LABEL,       best_h1_rf,  best_h2_xgb),
    (LGBM_LABEL,      best_h1_rf,  best_h2_lgbm),
]:
    x_arr = X_test_full.values if hasattr(X_test_full, 'values') else X_test_full
    y_arr = y_test_full.values if hasattr(y_test_full, 'values') else y_test_full
    res = hurdle_predict_full(x_arr, y_arr, best_h1_rf, h2_m,
                              {}, threshold=HURDLE_THRESHOLD,
                              label=f'Tuned  {tag}')
    hurdle_tuned_results[tag] = res

best_hurdle_tuned_tag = max(hurdle_tuned_results,
                            key=lambda k: hurdle_tuned_results[k]['r2'])
best_hurdle_tuned     = hurdle_tuned_results[best_hurdle_tuned_tag]
joblib.dump(best_h1_rf,
            f"outputs/models/hurdle_stage1_BEST_{best_h1_name.replace(' ','_')}_tuned.pkl")


