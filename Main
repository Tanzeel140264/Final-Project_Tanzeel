# ============================================================================
# INFERENCE FUNCTION
# ============================================================================

def predict_hurdle(new_df: pd.DataFrame,
                   hurdle_threshold: float = HURDLE_THRESHOLD) -> pd.DataFrame:
    """
    Run the full hurdle pipeline on new KPI observations.

    Parameters
    ----------
    new_df           : DataFrame with raw KPI columns (BLER, PRBS, RU, etc.)
    hurdle_threshold : probability cutoff for scheduling gate

    Returns
    -------
    DataFrame with added prediction and anomaly columns.
    """
    out = new_df.copy()

    out['BLER_High']         = (out['BLER'] > 0.1).astype(int)
    out['PRBS_Norm']         = out['PRBS'] / (out['PRBS'].max() + 1e-9)
    out['PRBS_Active']       = (out['PRBS'] > 0).astype(int)
    out['PRBS_High']         = (out['PRBS'] > out['PRBS'].median()).astype(int)
    out['RU_Norm']           = ((out['RU'] - out['RU'].min()) /
                                 (out['RU'].max() - out['RU'].min() + 1e-9))
    out['RU_High']           = (out['RU'] > out['RU'].median()).astype(int)
    out['Effective_Resource']= out['PRBS'] * (1 - out['BLER'])
    out['UE_Band_Encoded']   = pd.cut(out['UE_id'], bins=5, labels=False)
    out['Time_Norm']         = ((out['time'] - out['time'].min()) /
                                 (out['time'].max() - out['time'].min() + 1e-9))
    if 'SINR' in out.columns:
        out['SINR_Norm'] = ((out['SINR'] - out['SINR'].min()) /
                            (out['SINR'].max() - out['SINR'].min() + 1e-9))
        out['SINR_Good'] = (out['SINR'] > out['SINR'].median()).astype(int)
    if 'Latitude' in out.columns and 'Longitude' in out.columns:
        ref_lat = out['Latitude'].mean(); ref_lon = out['Longitude'].mean()
        R = 6371000
        dlat = np.radians(out['Latitude']  - ref_lat)
        dlon = np.radians(out['Longitude'] - ref_lon)
        a    = (np.sin(dlat/2)**2 +
                np.cos(np.radians(ref_lat)) * np.cos(np.radians(out['Latitude']))
                * np.sin(dlon/2)**2)
        out['Distance_m'] = R * 2 * np.arctan2(np.sqrt(a), np.sqrt(1-a))
    if 'Altitude' in out.columns:
        out['Altitude_Norm'] = ((out['Altitude'] - out['Altitude'].min()) /
                                 (out['Altitude'].max() - out['Altitude'].min() + 1e-9))
    if 'MobileState' in out.columns:
        state_map = {'stationary': 0, 'walking': 1, 'driving': 2}
        out['MobileState_Enc'] = (out['MobileState'].str.lower()
                                   .map(state_map).fillna(1).astype(int))

    X_new = out[[f for f in FEATURES if f in out.columns]]

    p_scheduled              = best_h1_model.predict_proba(X_new)[:, 1]
    is_scheduled             = (p_scheduled >= hurdle_threshold).astype(int)
    out['P_Scheduled']        = p_scheduled
    out['Is_Scheduled_Hurdle']= is_scheduled

    rf_raw   = np.clip(best_h2_rf.predict(X_new),   0, None)
    xgb_raw  = np.clip(best_h2_xgb.predict(X_new),  0, None)
    lgbm_raw = np.clip(best_h2_lgbm.predict(X_new), 0, None)
    ensemble = (rf_raw + xgb_raw + lgbm_raw) / 3.0

    out['Predicted_DL_RF']       = rf_raw   * is_scheduled
    out['Predicted_DL_XGB']      = xgb_raw  * is_scheduled
    out['Predicted_DL_LGBM']     = lgbm_raw * is_scheduled
    out['Predicted_DL_Ensemble'] = ensemble  * is_scheduled
    out['Hurdle_DL_Ensemble']    = ensemble  * is_scheduled

    out['Is_LowPerformance']  = best_cls_model.predict(X_new)
    out['Anomaly_Probability']= best_cls_model.predict_proba(X_new)[:, 1]

    return out


# ============================================================================
# PIPELINE COMPLETE
# ============================================================================
section("PIPELINE COMPLETE")
print(f"""
  Hurdle Stage 1 — Scheduling Gate:
    Best model : {best_h1_name}  (Gate AUC = {best_h1_auc:.4f})
    Trained on : ALL rows ({n_total:,})

  Hurdle Stage 2 — Throughput Regressor:
    Random Forest  R2 = {h2_rf_m_tuned['TestR2']:.4f}  RMSE = {h2_rf_m_tuned['RMSE']:.4f} Mbps
    {XGB_LABEL:<14} R2 = {h2_xgb_m_tuned['TestR2']:.4f}  RMSE = {h2_xgb_m_tuned['RMSE']:.4f} Mbps
    {LGBM_LABEL:<14} R2 = {h2_lgbm_m_tuned['TestR2']:.4f}  RMSE = {h2_lgbm_m_tuned['RMSE']:.4f} Mbps
    Winner : {best_h2_name}

  Combined Hurdle — Full-Population R2:
    Random Forest  R2 = {hurdle_tuned_results.get('Random Forest',{}).get('r2',0):.4f}
    {XGB_LABEL:<14} R2 = {hurdle_tuned_results.get(XGB_LABEL,{}).get('r2',0):.4f}
    {LGBM_LABEL:<14} R2 = {hurdle_tuned_results.get(LGBM_LABEL,{}).get('r2',0):.4f}
    Best Combo: {best_hurdle_tuned_tag}  (R2 = {best_hurdle_tuned['r2']:.4f})

