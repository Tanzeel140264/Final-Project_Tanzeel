    ax.text(0.04, 0.96, f'Pearson r = {r_d:+.3f}\n{p_d_str}',
            transform=ax.transAxes, fontsize=11, va='top',
            bbox=dict(boxstyle='round,pad=0.4', facecolor='white',
                      edgecolor='grey', alpha=0.88))
    ax.set_xlabel('Distance from centroid (m, 99th pctl clipped)')
    ax.set_ylabel('DL Throughput (Mbps)')
    ax.set_title('B5 — Distance vs DL Throughput\nFriis: P_rx proportional to 1/d^2 -> SINR down -> MCS down',
                 fontweight='bold', pad=12)
