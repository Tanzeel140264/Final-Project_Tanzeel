section("5-FOLD CROSS-VALIDATION — ALL MODELS")

cv_h2_rf   = cross_val_score(best_h2_rf,   X_active, y_active, cv=5, scoring='r2', n_jobs=-1)
cv_h2_xgb  = cross_val_score(best_h2_xgb,  X_active, y_active, cv=5, scoring='r2', n_jobs=-1)
cv_h2_lgbm = cross_val_score(best_h2_lgbm, X_active, y_active, cv=5, scoring='r2', n_jobs=-1)
cv_c_rf    = cross_val_score(best_rf_cls,   X_active, y_active < threshold_anom,
                             cv=5, scoring='roc_auc', n_jobs=-1)
cv_c_xgb   = cross_val_score(best_xgb_cls,  X_active, y_active < threshold_anom,
                             cv=5, scoring='roc_auc', n_jobs=-1)
cv_c_lgbm  = cross_val_score(best_lgbm_cls, X_active, y_active < threshold_anom,
                             cv=5, scoring='roc_auc', n_jobs=-1)

print(f"  Stage 2 Regressor R2  : "
      f"RF {cv_h2_rf.mean():.4f}+/-{cv_h2_rf.std():.4f}  |  "
      f"{XGB_LABEL} {cv_h2_xgb.mean():.4f}+/-{cv_h2_xgb.std():.4f}  |  "
      f"{LGBM_LABEL} {cv_h2_lgbm.mean():.4f}+/-{cv_h2_lgbm.std():.4f}")
print(f"  Stage 3 Anomaly AUC   : "
      f"RF {cv_c_rf.mean():.4f}+/-{cv_c_rf.std():.4f}  |  "
      f"{XGB_LABEL} {cv_c_xgb.mean():.4f}+/-{cv_c_xgb.std():.4f}  |  "
      f"{LGBM_LABEL} {cv_c_lgbm.mean():.4f}+/-{cv_c_lgbm.std():.4f}")


