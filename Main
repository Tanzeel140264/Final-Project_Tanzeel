               label='Active UE samples')
    lo = min(float(y_test_reg.min()), float(pred.min()))
    hi = max(float(y_test_reg.max()), float(pred.max()))
    ax.plot([lo, hi], [lo, hi], 'r--', lw=2.5, label='Ideal  y = x')
    m = h2_m_dict.get(name, h2_preds_dict)
    if isinstance(m, dict) and 'TestR2' in m:
        r2_val   = m['TestR2']
        rmse_val = m['RMSE']
    else:
        r2_val   = r2_score(y_test_reg, pred)
        rmse_val = np.sqrt(mean_squared_error(y_test_reg, pred))
    ax.set_title(f'Hurdle Stage 2 — Actual vs Predicted DL Throughput (Active UEs)\n'
                 f'{name}   R2 = {r2_val:.4f}   RMSE = {rmse_val:.4f} Mbps',
                 fontweight='bold', pad=14)
    ax.set_xlabel('Actual DL Throughput (Mbps)')
    ax.set_ylabel('Predicted DL Throughput (Mbps)')
    ax.legend(); ax.grid(alpha=0.25)
    plt.tight_layout()
    show_and_save(f'outputs/plots/fig2_actual_vs_predicted_{fname}.png')

