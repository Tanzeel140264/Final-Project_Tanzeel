# PART B – FEATURE ENGINEERING
# ============================================================================

section("PART B — FEATURE ENGINEERING")

df = df_merged.copy()

df['Time_Step']     = df['time']
df['Time_Norm']     = (df['time'] - df['time'].min()) / (df['time'].max() - df['time'].min())

df['UE_Band'] = pd.cut(df['UE_id'], bins=5,
                        labels=['Band_0_99','Band_100_199','Band_200_299',
                                'Band_300_399','Band_400_499'])
df['UE_Band_Encoded'] = df['UE_Band'].cat.codes

df['BLER_High']     = (df['BLER'] > 0.1).astype(int)
df['BLER_Category'] = pd.cut(df['BLER'],
                              bins=[-np.inf, 0, 0.01, 0.1, 0.5, np.inf],
                              labels=['Zero','Very_Low','Low','Medium','High'])
df['BLER_Cat_Enc']  = df['BLER_Category'].cat.codes

df['PRBS_Norm']     = df['PRBS'] / df['PRBS'].max()
df['PRBS_Active']   = (df['PRBS'] > 0).astype(int)
df['PRBS_High']     = (df['PRBS'] > df['PRBS'].median()).astype(int)

df['RU_Norm']       = (df['RU'] - df['RU'].min()) / (df['RU'].max() - df['RU'].min())
df['RU_High']       = (df['RU'] > df['RU'].median()).astype(int)

df['Effective_Resource'] = df['PRBS'] * (1 - df['BLER'])

if 'SINR' in df.columns:
    df['SINR_Norm'] = (df['SINR'] - df['SINR'].min()) / (df['SINR'].max() - df['SINR'].min())
    df['SINR_Good'] = (df['SINR'] > df['SINR'].median()).astype(int)
    print("  SINR features created")

if 'Latitude' in df.columns and 'Longitude' in df.columns:
    ref_lat = df['Latitude'].mean()
    ref_lon = df['Longitude'].mean()
    R = 6371000
    dlat = np.radians(df['Latitude']  - ref_lat)
    dlon = np.radians(df['Longitude'] - ref_lon)
    a    = (np.sin(dlat/2)**2 +
            np.cos(np.radians(ref_lat)) * np.cos(np.radians(df['Latitude']))
            * np.sin(dlon/2)**2)
    df['Distance_m'] = R * 2 * np.arctan2(np.sqrt(a), np.sqrt(1-a))
    df['Distance_m'] = df['Distance_m'].fillna(df['Distance_m'].median())
    print(f"  Distance_m created  (range: {df['Distance_m'].min():.0f}–"
          f"{df['Distance_m'].max():.0f} m)")

if 'Altitude' in df.columns:
    df['Altitude_Norm'] = ((df['Altitude'] - df['Altitude'].min()) /
                           (df['Altitude'].max() - df['Altitude'].min() + 1e-9))
    print("  Altitude_Norm created")

if 'MobileState' in df.columns:
    state_map = {'stationary': 0, 'walking': 1, 'driving': 2}
    df['MobileState_Enc'] = (df['MobileState'].str.lower()
                              .map(state_map)
                              .fillna(1)
                              .astype(int))
    print(f"  MobileState_Enc created  "
          f"(states: {df['MobileState'].unique()[:5]})")

print("  Feature engineering complete")
print(f"  Dataset shape after feature engineering: {df.shape}")

BASE_FEATURES = ['BLER', 'PRBS', 'RU',
                 'BLER_High', 'PRBS_Active', 'PRBS_High', 'RU_High',
                 'PRBS_Norm', 'RU_Norm',
                 'Effective_Resource', 'UE_id', 'UE_Band_Encoded',
                 'Time_Norm']

if 'SINR' in df.columns:
    BASE_FEATURES += ['SINR', 'SINR_Norm', 'SINR_Good']

if 'Distance_m' in df.columns:
    BASE_FEATURES += ['Distance_m']
if 'Altitude_Norm' in df.columns:
    BASE_FEATURES += ['Altitude_Norm']
if 'MobileState_Enc' in df.columns:
    BASE_FEATURES += ['MobileState_Enc']

FEATURES = [f for f in BASE_FEATURES if f in df.columns]
print(f"\n  Features for modelling ({len(FEATURES)}): {FEATURES}")


