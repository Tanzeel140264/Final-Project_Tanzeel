# ============================================================================
# PART D – MODEL PIPELINE  (HURDLE ARCHITECTURE)
# ============================================================================

section("PART D — MODEL PIPELINE  [TWO-STAGE HURDLE MODEL]")

print("""
  ALL ROWS  ->  Hurdle Stage 1 (Binary Classifier: is_scheduled?)
                     |
         +-----------+-----------+
         |                       |
    p < threshold           p >= threshold
  predicted THP = 0      Hurdle Stage 2 (Regressor: predicted THP = y Mbps)

  Stage 3 (unchanged): Anomaly classifier on active UEs only
""")

data_full = df[FEATURES + [TARGET_COL]].dropna()

n_total     = len(data_full)
n_zero      = (data_full[TARGET_COL] == 0).sum()
n_active    = (data_full[TARGET_COL] > 0).sum()
pct_zero    = n_zero   / n_total * 100
pct_active  = n_active / n_total * 100

print(f"\n  Full-Population Label Summary")
print(f"  Total rows              : {n_total:,}")
print(f"  Unscheduled (THP == 0)  : {n_zero:,}  ({pct_zero:.1f}%)")
print(f"  Active      (THP >  0)  : {n_active:,}  ({pct_active:.1f}%)")

data_full = data_full.copy()
data_full['is_scheduled'] = (data_full[TARGET_COL] > 0).astype(int)

X_full = data_full[FEATURES]
y_full = data_full[TARGET_COL]
y_hurdle = data_full['is_scheduled']

data_active = data_full[data_full[TARGET_COL] > 0].copy()
X_active    = data_active[FEATURES]
y_active    = data_active[TARGET_COL]

section("TRAIN / TEST SPLIT  (80 / 20)")
(X_train_full, X_test_full,
 y_train_hurdle, y_test_hurdle,
 y_train_full, y_test_full) = train_test_split(
    X_full, y_hurdle, y_full,
    test_size=TEST_SIZE, random_state=RANDOM_STATE)

train_active_mask = y_train_full > 0
test_active_mask  = y_test_full  > 0

X_train_reg = X_train_full[train_active_mask]
y_train_reg = y_train_full[train_active_mask]
X_test_reg  = X_test_full[test_active_mask]
y_test_reg  = y_test_full[test_active_mask]

print(f"  Full split    — Train: {len(X_train_full):,}  Test: {len(X_test_full):,}")
print(f"  Active subset — Train: {len(X_train_reg):,}  Test: {len(X_test_reg):,}")
print(f"  Hurdle labels — Train pos: {y_train_hurdle.sum():,}  "
      f"Train neg: {(y_train_hurdle==0).sum():,}")


# ============================================================================
# HURDLE STAGE 1 – SCHEDULING CLASSIFIER
# ============================================================================
section("HURDLE STAGE 1 — SCHEDULING CLASSIFIER")

if USE_SMOTE:
    minority_h = (y_train_hurdle == 1).sum()
    k_h        = min(5, minority_h - 1)
    if k_h >= 1:
        X_tr_h, y_tr_h = SMOTE(random_state=RANDOM_STATE,
                                 k_neighbors=k_h).fit_resample(
                                 X_train_full, y_train_hurdle)
        print(f"  SMOTE applied — Train after: pos={y_tr_h.sum():,} neg={(y_tr_h==0).sum():,}")
    else:
        X_tr_h, y_tr_h = X_train_full, y_train_hurdle
else:
    X_tr_h, y_tr_h = X_train_full, y_train_hurdle

pos_w_hurdle = (y_tr_h==0).sum() / max((y_tr_h==1).sum(), 1)

subsection("Hurdle Stage 1 — Model A: Random Forest Classifier")
h1_rf = RandomForestClassifier(n_estimators=200, max_depth=15,
                                min_samples_split=5, min_samples_leaf=2,
                                class_weight='balanced', max_features='sqrt',
                                n_jobs=-1, random_state=RANDOM_STATE)
h1_rf.fit(X_tr_h, y_tr_h)
h1_rf_pred  = h1_rf.predict(X_test_full)
h1_rf_proba = h1_rf.predict_proba(X_test_full)[:, 1]
print(classification_report(y_test_hurdle, h1_rf_pred,
                             target_names=['Unscheduled','Scheduled']))
h1_rf_auc = roc_auc_score(y_test_hurdle, h1_rf_proba)
print(f"  ROC-AUC: {h1_rf_auc:.4f}")

subsection(f"Hurdle Stage 1 — Model B: {XGB_LABEL} Classifier")
if USE_XGB:
    h1_xgb = XGBClassifier(n_estimators=300, max_depth=6, learning_rate=0.05,
                            subsample=0.8, colsample_bytree=0.8,
                            scale_pos_weight=pos_w_hurdle,
                            use_label_encoder=False, eval_metric='logloss',
                            n_jobs=-1, random_state=RANDOM_STATE, verbosity=0)
    h1_xgb.fit(X_tr_h, y_tr_h, eval_set=[(X_test_full, y_test_hurdle)], verbose=False)
else:
    h1_xgb = XGBClassifier(n_estimators=150, max_depth=5, learning_rate=0.1,
                            subsample=0.8, random_state=RANDOM_STATE)
    h1_xgb.fit(X_tr_h, y_tr_h)
h1_xgb_pred  = h1_xgb.predict(X_test_full)
h1_xgb_proba = h1_xgb.predict_proba(X_test_full)[:, 1]
print(classification_report(y_test_hurdle, h1_xgb_pred,
                             target_names=['Unscheduled','Scheduled']))
h1_xgb_auc = roc_auc_score(y_test_hurdle, h1_xgb_proba)
print(f"  ROC-AUC: {h1_xgb_auc:.4f}")

subsection(f"Hurdle Stage 1 — Model C: {LGBM_LABEL} Classifier")
if USE_LGBM:
    h1_lgbm = LGBMClassifier(n_estimators=300, max_depth=8, learning_rate=0.05,
                              num_leaves=63, min_child_samples=20, subsample=0.8,
                              colsample_bytree=0.8, scale_pos_weight=pos_w_hurdle,
                              class_weight='balanced', n_jobs=-1,
                              random_state=RANDOM_STATE, verbose=-1)
else:
    h1_lgbm = LGBMClassifier(n_estimators=150, max_depth=5, learning_rate=0.1,
                              subsample=0.8, random_state=RANDOM_STATE)
h1_lgbm.fit(X_tr_h, y_tr_h)
h1_lgbm_pred  = h1_lgbm.predict(X_test_full)
h1_lgbm_proba = h1_lgbm.predict_proba(X_test_full)[:, 1]
print(classification_report(y_test_hurdle, h1_lgbm_pred,
                             target_names=['Unscheduled','Scheduled']))
h1_lgbm_auc = roc_auc_score(y_test_hurdle, h1_lgbm_proba)
print(f"  ROC-AUC: {h1_lgbm_auc:.4f}")

best_h1_auc  = max(h1_rf_auc, h1_xgb_auc, h1_lgbm_auc)
if   h1_xgb_auc  >= h1_rf_auc and h1_xgb_auc  >= h1_lgbm_auc:
    best_h1_name  = XGB_LABEL;      best_h1_model = h1_xgb
    best_h1_proba = h1_xgb_proba;   best_h1_pred  = h1_xgb_pred
elif h1_lgbm_auc >= h1_rf_auc:
    best_h1_name  = LGBM_LABEL;     best_h1_model = h1_lgbm
    best_h1_proba = h1_lgbm_proba;  best_h1_pred  = h1_lgbm_pred
else:
    best_h1_name  = 'Random Forest'; best_h1_model = h1_rf
    best_h1_proba = h1_rf_proba;     best_h1_pred  = h1_rf_pred

print(f"\n  Best Hurdle Stage 1: {best_h1_name}  (AUC = {best_h1_auc:.4f})")
joblib.dump(best_h1_model, f'outputs/models/hurdle_stage1_{best_h1_name.replace(" ","_")}.pkl')


# ============================================================================
# HURDLE STAGE 2 – THROUGHPUT REGRESSOR
# ============================================================================
section("HURDLE STAGE 2 — THROUGHPUT REGRESSOR  (active rows only)")

subsection("Hurdle Stage 2 — Model A: Random Forest Regressor")
h2_rf = RandomForestRegressor(n_estimators=200, max_depth=20,
                               min_samples_split=5, min_samples_leaf=2,
                               max_features='sqrt', n_jobs=-1,
                               random_state=RANDOM_STATE)
h2_rf.fit(X_train_reg, y_train_reg)
h2_rf_pred = h2_rf.predict(X_test_reg)
h2_rf_m = {'TrainR2': r2_score(y_train_reg, h2_rf.predict(X_train_reg)),
            'TestR2' : r2_score(y_test_reg, h2_rf_pred),
            'RMSE'   : np.sqrt(mean_squared_error(y_test_reg, h2_rf_pred)),
            'MAE'    : mean_absolute_error(y_test_reg, h2_rf_pred)}
for k, v in h2_rf_m.items(): print(f"    {k:<10}: {v:.4f}")

subsection(f"Hurdle Stage 2 — Model B: {XGB_LABEL} Regressor")
if USE_XGB:
    h2_xgb = XGBRegressor(n_estimators=300, max_depth=8, learning_rate=0.05,
                           subsample=0.8, colsample_bytree=0.8, reg_alpha=0.1,
                           reg_lambda=1.0, n_jobs=-1, random_state=RANDOM_STATE,
                           verbosity=0)
    h2_xgb.fit(X_train_reg, y_train_reg,
               eval_set=[(X_test_reg, y_test_reg)], verbose=False)
else:
    h2_xgb = XGBRegressor(n_estimators=200, max_depth=6, learning_rate=0.1,
                           subsample=0.8, random_state=RANDOM_STATE)
    h2_xgb.fit(X_train_reg, y_train_reg)
h2_xgb_pred = h2_xgb.predict(X_test_reg)
h2_xgb_m = {'TrainR2': r2_score(y_train_reg, h2_xgb.predict(X_train_reg)),
             'TestR2' : r2_score(y_test_reg, h2_xgb_pred),
             'RMSE'   : np.sqrt(mean_squared_error(y_test_reg, h2_xgb_pred)),
             'MAE'    : mean_absolute_error(y_test_reg, h2_xgb_pred)}
for k, v in h2_xgb_m.items(): print(f"    {k:<10}: {v:.4f}")

subsection(f"Hurdle Stage 2 — Model C: {LGBM_LABEL} Regressor")
if USE_LGBM:
    h2_lgbm = LGBMRegressor(n_estimators=300, max_depth=8, learning_rate=0.05,
                             num_leaves=63, min_child_samples=20, subsample=0.8,
                             colsample_bytree=0.8, reg_alpha=0.1, reg_lambda=1.0,
                             n_jobs=-1, random_state=RANDOM_STATE, verbose=-1)
else:
    h2_lgbm = LGBMRegressor(n_estimators=200, max_depth=6, learning_rate=0.1,
                             subsample=0.8, random_state=RANDOM_STATE)
h2_lgbm.fit(X_train_reg, y_train_reg)
h2_lgbm_pred = np.clip(h2_lgbm.predict(X_test_reg), 0, None)
h2_lgbm_m = {'TrainR2': r2_score(y_train_reg, np.clip(h2_lgbm.predict(X_train_reg), 0, None)),
              'TestR2' : r2_score(y_test_reg, h2_lgbm_pred),
              'RMSE'   : np.sqrt(mean_squared_error(y_test_reg, h2_lgbm_pred)),
              'MAE'    : mean_absolute_error(y_test_reg, h2_lgbm_pred)}
for k, v in h2_lgbm_m.items(): print(f"    {k:<10}: {v:.4f}")

if   h2_xgb_m['TestR2']  >= h2_rf_m['TestR2'] and h2_xgb_m['TestR2']  >= h2_lgbm_m['TestR2']:
    best_h2_name  = XGB_LABEL;       best_h2_model = h2_xgb;  best_h2_pred = h2_xgb_pred;  best_h2_m = h2_xgb_m
elif h2_lgbm_m['TestR2'] >= h2_rf_m['TestR2']:
    best_h2_name  = LGBM_LABEL;      best_h2_model = h2_lgbm; best_h2_pred = h2_lgbm_pred; best_h2_m = h2_lgbm_m
else:
    best_h2_name  = 'Random Forest'; best_h2_model = h2_rf;   best_h2_pred = h2_rf_pred;   best_h2_m = h2_rf_m

print(f"\n  Best Hurdle Stage 2: {best_h2_name}  "
      f"(R2 = {best_h2_m['TestR2']:.4f}  RMSE = {best_h2_m['RMSE']:.4f})")
joblib.dump(best_h2_model, f'outputs/models/hurdle_stage2_{best_h2_name.replace(" ","_")}.pkl')


# ============================================================================
# COMBINED HURDLE EVALUATION
# ============================================================================
section("COMBINED HURDLE EVALUATION — Full test-set R2 (zeros included)")

def hurdle_predict_full(X_test_all, y_test_all,
                        h1_model, h2_model, h2_models_dict,
                        threshold=HURDLE_THRESHOLD, label='Best models'):
    proba     = h1_model.predict_proba(X_test_all)[:, 1]
    scheduled = proba >= threshold
    y_hat     = np.zeros(len(X_test_all))

    if scheduled.sum() > 0:
        reg_preds          = np.clip(h2_model.predict(X_test_all[scheduled]), 0, None)
        y_hat[scheduled]   = reg_preds

    r2_combined   = r2_score(y_test_all, y_hat)
    rmse_combined = np.sqrt(mean_squared_error(y_test_all, y_hat))
    mae_combined  = mean_absolute_error(y_test_all, y_hat)

    pred_sched = (proba >= threshold).astype(int)
    true_sched = (y_test_all > 0).astype(int)
    gate_auc   = roc_auc_score(true_sched, proba)

    print(f"\n  [{label}]")
    print(f"  Hurdle gate AUC              : {gate_auc:.4f}")
    print(f"  Scheduled rows predicted     : {scheduled.sum():,} / {len(X_test_all):,} "
          f"({scheduled.mean()*100:.1f}%)")
    print(f"  Combined R2  (full pop.)     : {r2_combined:.4f}   <- KEY METRIC")
    print(f"  Combined RMSE (full pop.)    : {rmse_combined:.4f} Mbps")
    print(f"  Combined MAE  (full pop.)    : {mae_combined:.4f} Mbps")

    return {
        'y_hat': y_hat, 'proba': proba, 'scheduled': scheduled,
        'r2': r2_combined, 'rmse': rmse_combined, 'mae': mae_combined,
        'gate_auc': gate_auc
    }


hurdle_results = {}

for tag, h1_m, h2_m in [
    ('Random Forest', h1_rf,   h2_rf),
    (XGB_LABEL,       h1_xgb,  h2_xgb),
    (LGBM_LABEL,      h1_lgbm, h2_lgbm),
]:
    res = hurdle_predict_full(
        X_test_full.values if hasattr(X_test_full, 'values') else X_test_full,
        y_test_full.values if hasattr(y_test_full, 'values') else y_test_full,
        h1_m, h2_m, {}, threshold=HURDLE_THRESHOLD, label=tag)
    hurdle_results[tag] = res

best_hurdle_tag = max(hurdle_results, key=lambda k: hurdle_results[k]['r2'])
best_hurdle     = hurdle_results[best_hurdle_tag]
print(f"\n  Best hurdle combo: {best_hurdle_tag}  "
      f"(combined R2 = {best_hurdle['r2']:.4f})")


# ============================================================================
# ANOMALY LABELS  (Stage 3)
# ============================================================================
section(f"STAGE 3 ANOMALY LABELS  (bottom {LOW_PERF_PCTILE}th percentile of active samples)")

pctile = LOW_PERF_PCTILE
while pctile <= 90:
    threshold_anom = np.percentile(y_train_reg, pctile)
    y_cls_train    = (y_train_reg < threshold_anom).astype(int)
    if y_cls_train.nunique() == 2:
        break
    pctile += 5

if y_cls_train.nunique() < 2:
    threshold_anom = y_train_reg.median()
    y_cls_train    = (y_train_reg < threshold_anom).astype(int)

y_cls_test = (y_test_reg < threshold_anom).astype(int)
print(f"  Threshold : {threshold_anom:.4f} Mbps")
print(f"  Train  ->  Normal: {(y_cls_train==0).sum():,}  "
      f"|  Anomaly: {(y_cls_train==1).sum():,}")

if USE_SMOTE:
    subsection("Handling Imbalance with SMOTE")
    minority_count = (y_cls_train == 1).sum()
    k_neighbors    = min(5, minority_count - 1)
    if k_neighbors >= 1:
        X_tr_bal, y_tr_bal = SMOTE(random_state=RANDOM_STATE,
                                    k_neighbors=k_neighbors).fit_resample(
                                    X_train_reg, y_cls_train)
        print(f"  After SMOTE -> Normal: {(y_tr_bal==0).sum():,}  "
              f"|  Anomaly: {(y_tr_bal==1).sum():,}")
    else:
        X_tr_bal, y_tr_bal = X_train_reg, y_cls_train
else:
    X_tr_bal, y_tr_bal = X_train_reg, y_cls_train

pos_w = (y_tr_bal==0).sum() / max((y_tr_bal==1).sum(), 1)


# ============================================================================
# STAGE 3 – ANOMALY CLASSIFICATION
# ============================================================================
section("STAGE 3 — ANOMALY CLASSIFICATION: Flagging Low-Performance UEs")

subsection("Stage 3 — Model A: Random Forest Classifier")
rf_cls = RandomForestClassifier(n_estimators=200, max_depth=15,
                                 min_samples_split=5, min_samples_leaf=2,
                                 class_weight='balanced', max_features='sqrt',
                                 n_jobs=-1, random_state=RANDOM_STATE)
rf_cls.fit(X_tr_bal, y_tr_bal)
rf_cp  = rf_cls.predict(X_test_reg)
_proba = rf_cls.predict_proba(X_test_reg)
rf_cpr = _proba[:,1] if _proba.shape[1] > 1 else _proba[:,0]
print(classification_report(y_cls_test, rf_cp, target_names=["Normal","Low-Performance"]))
rf_auc = roc_auc_score(y_cls_test, rf_cpr)
print(f"  ROC-AUC: {rf_auc:.4f}")

subsection(f"Stage 3 — Model B: {XGB_LABEL} Classifier")
if USE_XGB:
    xgb_cls = XGBClassifier(n_estimators=300, max_depth=6, learning_rate=0.05,
                             subsample=0.8, colsample_bytree=0.8,
                             scale_pos_weight=pos_w, use_label_encoder=False,
                             eval_metric='logloss', n_jobs=-1,
                             random_state=RANDOM_STATE, verbosity=0)
    xgb_cls.fit(X_tr_bal, y_tr_bal, eval_set=[(X_test_reg, y_cls_test)], verbose=False)
else:
    xgb_cls = XGBClassifier(n_estimators=150, max_depth=5, learning_rate=0.1,
                             subsample=0.8, random_state=RANDOM_STATE)
    xgb_cls.fit(X_tr_bal, y_tr_bal)
xgb_cp  = xgb_cls.predict(X_test_reg)
_proba2 = xgb_cls.predict_proba(X_test_reg)
xgb_cpr = _proba2[:,1] if _proba2.shape[1] > 1 else _proba2[:,0]
print(classification_report(y_cls_test, xgb_cp, target_names=["Normal","Low-Performance"]))
xgb_auc = roc_auc_score(y_cls_test, xgb_cpr)
print(f"  ROC-AUC: {xgb_auc:.4f}")

subsection(f"Stage 3 — Model C: {LGBM_LABEL} Classifier")
if USE_LGBM:
    lgbm_cls = LGBMClassifier(n_estimators=300, max_depth=8, learning_rate=0.05,
                               num_leaves=63, min_child_samples=20, subsample=0.8,
                               colsample_bytree=0.8, scale_pos_weight=pos_w,
                               class_weight='balanced', reg_alpha=0.1,
                               reg_lambda=1.0, n_jobs=-1,
                               random_state=RANDOM_STATE, verbose=-1)
else:
    lgbm_cls = LGBMClassifier(n_estimators=150, max_depth=5, learning_rate=0.1,
                               subsample=0.8, random_state=RANDOM_STATE)
lgbm_cls.fit(X_tr_bal, y_tr_bal)
lgbm_cp   = lgbm_cls.predict(X_test_reg)
_proba3   = lgbm_cls.predict_proba(X_test_reg)
lgbm_cpr  = _proba3[:,1] if _proba3.shape[1] > 1 else _proba3[:,0]
print(classification_report(y_cls_test, lgbm_cp, target_names=["Normal","Low-Performance"]))
lgbm_auc = roc_auc_score(y_cls_test, lgbm_cpr)
print(f"  ROC-AUC: {lgbm_auc:.4f}")

if   xgb_auc  >= rf_auc and xgb_auc  >= lgbm_auc:
    best_cls_name  = XGB_LABEL;       best_cls_model = xgb_cls
    best_cls_pred  = xgb_cp;          best_cls_proba = xgb_cpr;  best_cls_auc = xgb_auc
elif lgbm_auc >= rf_auc:
    best_cls_name  = LGBM_LABEL;      best_cls_model = lgbm_cls
    best_cls_pred  = lgbm_cp;         best_cls_proba = lgbm_cpr; best_cls_auc = lgbm_auc
else:
    best_cls_name  = 'Random Forest'; best_cls_model = rf_cls
    best_cls_pred  = rf_cp;           best_cls_proba = rf_cpr;   best_cls_auc = rf_auc

print(f"\n  Best Stage 3 Classifier: {best_cls_name}  (AUC = {best_cls_auc:.4f})")
joblib.dump(best_cls_model,
            f"outputs/models/stage3_{best_cls_name.replace(' ','_')}.pkl")


# ============================================================================
# HYPERPARAMETER TUNING
# ============================================================================

section("HYPERPARAMETER TUNING — HURDLE STAGE 1, STAGE 2 & STAGE 3")

N_ITER_RANDOM   = 30
CV_FOLDS        = 3
HP_RANDOM_STATE = RANDOM_STATE


def report_search(search, stage_label):
    results = pd.DataFrame(search.cv_results_)
    cols    = [c for c in results.columns if 'param_' in c or c in
               ('mean_test_score','std_test_score','rank_test_score')]
    print(f"\n  Top-5 parameter sets for {stage_label}:")
    print(results.sort_values('rank_test_score').head(5)[cols].to_string(index=False))
    print(f"\n  Best score: {search.best_score_:.4f}")
    print(f"  Best params: {search.best_params_}")


subsection("Hurdle Stage 1 Tuning — Random Forest Classifier (RandomizedSearchCV)")
h1_rf_param_dist = {
    'n_estimators'     : [100,200,300,500],
    'max_depth'        : [5,10,15,20,None],
    'min_samples_split': [2,5,10],
    'min_samples_leaf' : [1,2,4],
    'max_features'     : ['sqrt','log2',0.5],
    'class_weight'     : ['balanced','balanced_subsample',None],
    'bootstrap'        : [True,False],
}
h1_rf_random = RandomizedSearchCV(
    RandomForestClassifier(n_jobs=-1, random_state=HP_RANDOM_STATE),
    h1_rf_param_dist, n_iter=N_ITER_RANDOM, scoring='roc_auc',
    cv=CV_FOLDS, verbose=1, random_state=HP_RANDOM_STATE, n_jobs=-1, refit=True)
h1_rf_random.fit(X_tr_h, y_tr_h)
report_search(h1_rf_random, 'Hurdle Stage 1 RF — RandomizedSearchCV')

subsection("Hurdle Stage 1 Tuning — Random Forest Classifier (GridSearchCV — focused)")
best_h1_rf_rnd = h1_rf_random.best_params_
h1_rf_grid_params = {
    'n_estimators': sorted(set([max(50,best_h1_rf_rnd['n_estimators']-100),
                                 best_h1_rf_rnd['n_estimators'],
                                 best_h1_rf_rnd['n_estimators']+100])),
    'max_depth'        : [best_h1_rf_rnd['max_depth']],
    'min_samples_split': sorted(set([max(2,best_h1_rf_rnd['min_samples_split']-2),
                                      best_h1_rf_rnd['min_samples_split'],
                                      min(20,best_h1_rf_rnd['min_samples_split']+2)])),
    'min_samples_leaf' : [best_h1_rf_rnd['min_samples_leaf']],
    'max_features'     : [best_h1_rf_rnd['max_features']],
    'class_weight'     : [best_h1_rf_rnd['class_weight']],
    'bootstrap'        : [best_h1_rf_rnd['bootstrap']],
}
h1_rf_grid = GridSearchCV(
    RandomForestClassifier(n_jobs=-1, random_state=HP_RANDOM_STATE),
    h1_rf_grid_params, scoring='roc_auc', cv=CV_FOLDS, verbose=1, n_jobs=-1, refit=True)
h1_rf_grid.fit(X_tr_h, y_tr_h)
report_search(h1_rf_grid, 'Hurdle Stage 1 RF — GridSearchCV')
best_h1_rf = h1_rf_grid.best_estimator_
joblib.dump(best_h1_rf, 'outputs/models/hurdle_stage1_RF_tuned.pkl')

subsection("Hurdle Stage 2 Tuning — Random Forest Regressor (RandomizedSearchCV)")
h2_rf_param_dist = {
    'n_estimators'     : [100,200,300,500],
    'max_depth'        : [10,15,20,30,None],
    'min_samples_split': [2,5,10],
    'min_samples_leaf' : [1,2,4],
    'max_features'     : ['sqrt','log2',0.5,0.8],
    'bootstrap'        : [True,False],
}
h2_rf_random = RandomizedSearchCV(
    RandomForestRegressor(n_jobs=-1, random_state=HP_RANDOM_STATE),
    h2_rf_param_dist, n_iter=N_ITER_RANDOM, scoring='r2',
    cv=CV_FOLDS, verbose=1, random_state=HP_RANDOM_STATE, n_jobs=-1, refit=True)
h2_rf_random.fit(X_train_reg, y_train_reg)
report_search(h2_rf_random, 'Hurdle Stage 2 RF — RandomizedSearchCV')

subsection("Hurdle Stage 2 Tuning — Random Forest Regressor (GridSearchCV — focused)")
best_h2_rf_rnd = h2_rf_random.best_params_
h2_rf_grid_params = {
    'n_estimators': sorted(set([max(50,best_h2_rf_rnd['n_estimators']-100),
                                 best_h2_rf_rnd['n_estimators'],
                                 best_h2_rf_rnd['n_estimators']+100])),
    'max_depth'        : [best_h2_rf_rnd['max_depth']],
    'min_samples_split': sorted(set([max(2,best_h2_rf_rnd['min_samples_split']-2),
                                      best_h2_rf_rnd['min_samples_split'],
                                      min(20,best_h2_rf_rnd['min_samples_split']+2)])),
    'min_samples_leaf' : [best_h2_rf_rnd['min_samples_leaf']],
    'max_features'     : [best_h2_rf_rnd['max_features']],
    'bootstrap'        : [best_h2_rf_rnd['bootstrap']],
}
h2_rf_grid = GridSearchCV(
    RandomForestRegressor(n_jobs=-1, random_state=HP_RANDOM_STATE),
    h2_rf_grid_params, scoring='r2', cv=CV_FOLDS, verbose=1, n_jobs=-1, refit=True)
h2_rf_grid.fit(X_train_reg, y_train_reg)
report_search(h2_rf_grid, 'Hurdle Stage 2 RF — GridSearchCV')
best_h2_rf = h2_rf_grid.best_estimator_
joblib.dump(best_h2_rf, 'outputs/models/hurdle_stage2_RF_tuned.pkl')

subsection(f"Hurdle Stage 2 Tuning — {XGB_LABEL} Regressor (RandomizedSearchCV)")
if USE_XGB:
    h2_xgb_param_dist = {
        'n_estimators'    : [100,200,300,500],
        'max_depth'       : [3,5,6,8,10],
        'learning_rate'   : [0.01,0.03,0.05,0.1,0.2],
        'subsample'       : [0.6,0.7,0.8,0.9,1.0],
        'colsample_bytree': [0.5,0.6,0.7,0.8,1.0],
        'reg_alpha'       : [0,0.01,0.1,0.5,1.0],
        'reg_lambda'      : [0.5,1.0,2.0,5.0],
        'min_child_weight': [1,3,5,7],
        'gamma'           : [0,0.1,0.3,0.5],
    }
    h2_xgb_random = RandomizedSearchCV(
        XGBRegressor(n_jobs=-1, random_state=HP_RANDOM_STATE, verbosity=0),
        h2_xgb_param_dist, n_iter=N_ITER_RANDOM, scoring='r2',
        cv=CV_FOLDS, verbose=1, random_state=HP_RANDOM_STATE, n_jobs=-1, refit=True)
    h2_xgb_random.fit(X_train_reg, y_train_reg)
    report_search(h2_xgb_random, f'Hurdle Stage 2 {XGB_LABEL} — RandomizedSearchCV')

    best_h2_xgb_rnd = h2_xgb_random.best_params_
    h2_xgb_grid_params = {
        'n_estimators'    : sorted(set([max(50,best_h2_xgb_rnd['n_estimators']-100),
                                         best_h2_xgb_rnd['n_estimators'],
                                         best_h2_xgb_rnd['n_estimators']+100])),
        'max_depth'       : [best_h2_xgb_rnd['max_depth']],
        'learning_rate'   : [best_h2_xgb_rnd['learning_rate']],
        'subsample'       : [best_h2_xgb_rnd['subsample']],
        'colsample_bytree': [best_h2_xgb_rnd['colsample_bytree']],
        'reg_alpha'       : [best_h2_xgb_rnd['reg_alpha']],
        'reg_lambda'      : [best_h2_xgb_rnd['reg_lambda']],
        'min_child_weight': [best_h2_xgb_rnd['min_child_weight']],
        'gamma'           : [best_h2_xgb_rnd['gamma']],
    }
    h2_xgb_grid = GridSearchCV(
        XGBRegressor(n_jobs=-1, random_state=HP_RANDOM_STATE, verbosity=0),
        h2_xgb_grid_params, scoring='r2', cv=CV_FOLDS, verbose=1, n_jobs=-1, refit=True)
    h2_xgb_grid.fit(X_train_reg, y_train_reg)
    report_search(h2_xgb_grid, f'Hurdle Stage 2 {XGB_LABEL} — GridSearchCV')
    best_h2_xgb = h2_xgb_grid.best_estimator_
else:
    h2_xgb_random = RandomizedSearchCV(
        XGBRegressor(random_state=HP_RANDOM_STATE),
        {'n_estimators':[100,200],'max_depth':[3,5,6],'learning_rate':[0.05,0.1]},
        n_iter=10, scoring='r2', cv=CV_FOLDS, verbose=1,
        random_state=HP_RANDOM_STATE, n_jobs=-1, refit=True)
    h2_xgb_random.fit(X_train_reg, y_train_reg)
    best_h2_xgb = h2_xgb_random.best_estimator_
joblib.dump(best_h2_xgb,
            f'outputs/models/hurdle_stage2_{XGB_LABEL.replace(" ","_")}_tuned.pkl')

