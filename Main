# Fig 0: Architecture Diagram
fig, ax = plt.subplots(figsize=(SLIDE_W, SLIDE_H))
ax.axis('off')
diagram = """
  ALL UE Observations (scheduled + unscheduled)
                      |
                      v
     HURDLE STAGE 1 — Scheduling Gate
     Binary Classifier (is_scheduled?)
     RF / XGBoost / LightGBM
                      |
         +------------+------------+
         |                         |
    p < threshold             p >= threshold
         |                         |
  Predicted THP = 0        HURDLE STAGE 2 — Regressor
  (unscheduled / idle)     Predicted THP = y Mbps
                           RF / XGBoost / LightGBM
                                   |
                                   v
                           STAGE 3 — Anomaly Flag
                           (active UEs only)
                           is_low_performance?
"""
ax.text(0.5, 0.5, diagram, transform=ax.transAxes, ha='center', va='center',
        fontsize=12, fontfamily='monospace',
        bbox=dict(boxstyle='round', facecolor='#f0f4f8', edgecolor='#2c3e50', linewidth=2))
ax.set_title('Hurdle Model Architecture — 5G Throughput Prediction',
             fontsize=15, fontweight='bold', pad=20)
plt.tight_layout()
show_and_save('outputs/plots/fig0_hurdle_architecture.png')

# Fig 1: Hurdle Stage 1 ROC Curve
fig, ax = plt.subplots(figsize=(SLIDE_W, SLIDE_H))
for (name, model, proba), ls in zip(
    [('Random Forest', h1_rf,  h1_rf_proba),
     (XGB_LABEL,       h1_xgb, h1_xgb_proba),
     (LGBM_LABEL,      h1_lgbm, h1_lgbm_proba)], line_styles):
    fp, tp, _ = roc_curve(y_test_hurdle, proba)
    auc_val   = roc_auc_score(y_test_hurdle, proba)
    ax.plot(fp, tp, lw=2.8, ls=ls, label=f'{name}  AUC = {auc_val:.4f}')
ax.plot([0,1],[0,1],'k--',lw=1.5,alpha=0.5,label='Random classifier')
ax.set_title('Hurdle Stage 1 — ROC Curves: Scheduling Gate\n'
             'Classifying Scheduled (THP>0) vs Unscheduled (THP=0) UEs',
             fontweight='bold', pad=14)
ax.set_xlabel('False Positive Rate'); ax.set_ylabel('True Positive Rate')
ax.legend(loc='lower right'); ax.grid(alpha=0.25)
plt.tight_layout()
show_and_save('outputs/plots/fig1_hurdle_stage1_roc.png')

# Fig 2: Actual vs Predicted — Stage 2
