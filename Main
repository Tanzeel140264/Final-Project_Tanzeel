section("PART A — LOADING, MELTING & MERGING ALL FILES")


def load_and_melt(filepath, metric_name, nrows_wide=None):
    if not os.path.exists(filepath):
        print(f"  File not found, skipping: {filepath}")
        return None

    df = pd.read_csv(filepath, nrows=nrows_wide, sep=None, engine='python')

    if 'time' in df.columns:
        print(f"  Loaded {metric_name}: {len(df):,} time steps x {len(df.columns)-1} UEs")
        long = df.melt(id_vars='time', var_name='UE_col', value_name=metric_name)
        long['UE_id'] = long['UE_col'].str.extract(r'(\d+)').astype(int)
        return long[['time', 'UE_id', metric_name]]

    if 'timeStamp' in df.columns:
        print(f"  Loaded Positions: {len(df):,} time steps, parsing UE groups...")
        records = []
        cols    = list(df.columns)
        ue_cols = cols[1:]
        n_groups = len(ue_cols) // 5

        for row_idx, row in df.iterrows():
            ts = row['timeStamp']
            for g in range(n_groups):
                base = g * 5
                try:
                    ue_id  = int(float(str(row[ue_cols[base]]).strip()))
                    lat    = float(row[ue_cols[base + 1]])
                    lon    = float(row[ue_cols[base + 2]])
                    alt    = float(row[ue_cols[base + 3]])
                    state  = row[ue_cols[base + 4]]
                    records.append({
                        'time'        : ts,
                        'UE_id'       : ue_id,
                        'Latitude'    : lat,
                        'Longitude'   : lon,
                        'Altitude'    : alt,
                        'MobileState' : str(state).strip(),
                    })
                except (ValueError, IndexError):
                    continue

        pos_df = pd.DataFrame(records)
        print(f"  Positions parsed: {len(pos_df):,} rows  "
              f"({pos_df['UE_id'].nunique()} UEs)")
        return pos_df

    print(f"  Skipping {metric_name}: unrecognised column structure.")
    print(f"     First 5 columns: {list(df.columns[:5])}")
    return None


WIDE_ROWS = int(np.ceil(N_ROWS_LIMIT / 500)) + 5

print(f"\n  Strategy: read first {WIDE_ROWS} time steps from each file")
print(f"  -> ~{WIDE_ROWS * 500:,} long rows per file -> merge on (time, UE_id)")
print(f"  -> aggregate into {TIME_WINDOW_SIZE}-tick windows")
print(f"  -> target: ~{(WIDE_ROWS // TIME_WINDOW_SIZE) * 500:,} aggregated rows\n")

melted = {}

for name in ['BLER', 'PRBS', 'RU', 'Throughput']:
    melted[name] = load_and_melt(FILE_PATHS[name], name, nrows_wide=WIDE_ROWS)

for name in ['SINR']:
    if os.path.exists(FILE_PATHS[name]):
        melted[name] = load_and_melt(FILE_PATHS[name], name, nrows_wide=WIDE_ROWS)
        if melted[name] is not None:
            print(f"  {name} loaded: {len(melted[name]):,} rows")
    else:
        print(f"  SINR file not yet available — will be added when uploaded")

pos_df = None
if os.path.exists(FILE_PATHS['Positions']):
    pos_df = load_and_melt(FILE_PATHS['Positions'], 'Positions', nrows_wide=WIDE_ROWS)
    if pos_df is not None:
        print(f"  Positions loaded: {len(pos_df):,} rows")
else:
    print(f"  Positions file not yet available — will be added when uploaded")

available = [k for k, v in melted.items() if v is not None]
print(f"\n  Merging {len(available)} standard file(s): {available}")

df_merged = melted['Throughput']
for name in available:
    if name == 'Throughput':
        continue
    df_merged = df_merged.merge(melted[name], on=['time', 'UE_id'], how='inner')

if pos_df is not None:
    pos_merge = pos_df.rename(columns={'time': 'time'}).copy()
    df_merged = df_merged.merge(
        pos_merge[['time', 'UE_id', 'Latitude', 'Longitude', 'Altitude', 'MobileState']],
        on=['time', 'UE_id'], how='left'
    )
    print(f"  Positions merged: Latitude, Longitude, Altitude, MobileState added")

df_merged = df_merged.sort_values(['time', 'UE_id']).reset_index(drop=True)

time_vals    = sorted(df_merged['time'].unique())
time_rank    = {t: i for i, t in enumerate(time_vals)}
df_merged['time_rank']   = df_merged['time'].map(time_rank)
df_merged['time_window'] = df_merged['time_rank'] // TIME_WINDOW_SIZE

agg_rules = {
    'Throughput': 'sum',
    'BLER'      : 'mean',
    'PRBS'      : 'mean',
    'RU'        : 'mean',
}
for col in ['SINR', 'Latitude', 'Longitude', 'Altitude']:
    if col in df_merged.columns:
        agg_rules[col] = 'mean'
if 'MobileState' in df_merged.columns:
    agg_rules['MobileState'] = lambda x: x.mode()[0] if len(x) > 0 else 'unknown'

agg_rules = {k: v for k, v in agg_rules.items() if k in df_merged.columns}

df_agg = (df_merged
          .groupby(['UE_id', 'time_window'])
          .agg(agg_rules)
          .reset_index())

window_to_time = (df_merged.groupby('time_window')['time'].min()
                  .reset_index()
                  .rename(columns={'time': 'time'}))
df_agg = df_agg.merge(window_to_time, on='time_window', how='left')

n_raw    = len(df_merged)
n_agg    = len(df_agg)
zero_raw = (df_merged['Throughput'] == 0).mean() * 100
zero_agg = (df_agg['Throughput']    == 0).mean() * 100

print(f"\n  Temporal Aggregation Results (window = {TIME_WINDOW_SIZE} ticks)")
print(f"  Raw rows        : {n_raw:,}   ->  Aggregated rows: {n_agg:,}")
print(f"  Zero-THP (raw)  : {zero_raw:.1f}%  ->  Zero-THP (agg) : {zero_agg:.1f}%")
print(f"  Aggregated THP mean: {df_agg['Throughput'].mean():.4f} Mbps")
print(f"  Aggregated THP (active only): "
      f"{df_agg[df_agg['Throughput']>0]['Throughput'].mean():.4f} Mbps\n")

df_merged = df_agg.copy()

print(f"\n  Merged dataset shape : {df_merged.shape}")
print(f"  Time steps  : {df_merged['time'].nunique()} "
      f"({df_merged['time'].min()} -> {df_merged['time'].max()})")
print(f"  UE IDs      : {df_merged['UE_id'].nunique()} (0 -> {df_merged['UE_id'].max()})")
print(f"\n  Column summary:")
for col in df_merged.columns:
    s = df_merged[col]
    nulls = s.isnull().sum()
    if pd.api.types.is_numeric_dtype(s):
        print(f"    {col:<20} dtype={str(s.dtype):<10} "
              f"min={s.min():.3f}  max={s.max():.3f}  "
              f"mean={s.mean():.3f}  nulls={nulls}")
    else:
        uniq = s.dropna().unique()[:4]
        print(f"    {col:<20} dtype={str(s.dtype):<10} "
              f"unique values={list(uniq)}  nulls={nulls}")

df_merged.to_csv(MERGED_FILE, index=False)
print(f"\n  Master dataset saved -> {MERGED_FILE}")
print(f"  Shape   : {df_merged.shape[0]:,} rows x {df_merged.shape[1]} columns")
print(f"  Columns : {list(df_merged.columns)}")

if IN_COLAB:
    print("  To download: Colab sidebar -> Files -> /content/master_5g_dataset.csv -> right-click -> Download")


